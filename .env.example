# Copy to ".env" in this folder (same directory as run.py). Never commit the real file.
# Restart: Ctrl+C then `python run.py`

# --- Chatbot (POST /api/chat) — Mistral (recommended) or OpenAI ---
MISTRAL_API_KEY=
# Optional: Mistral Agent (beta). Leave blank to use chat completions only.
#MISTRAL_AGENT_ID=
#MISTRAL_AGENT_VERSION=0
#MISTRAL_MODEL=mistral-small-latest

# Optional alternative:
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini
