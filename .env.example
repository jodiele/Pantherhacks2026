# Option A: Copy this file to ".env" in this folder (same directory as run.py).
# Option B: Put keys in the parent folder’s ".env" (e.g. Skintology/.env) — Flask loads that too
#   if the variable is not set in this folder’s .env.
# Never commit real secrets. Restart Flask after changes: Ctrl+C then `python run.py`

# --- Chatbot (POST /api/chat) — Mistral (recommended) or OpenAI ---
# Names must match exactly (not VITE_* — those are frontend-only).
MISTRAL_API_KEY=
# Optional: Mistral Agent (beta). Leave blank to use chat completions only.
#MISTRAL_AGENT_ID=
#MISTRAL_AGENT_VERSION=0
#MISTRAL_MODEL=mistral-small-latest

# Optional alternative:
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini
